# LiveKit Cloud (same project as the server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Voice pipeline providers
RUMIK_API_KEY=your_rumik_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key

# LLM: openai/gpt-oss-120b served on Groq's OpenAI-compatible endpoint
GROQ_API_KEY=your_groq_api_key

# Optional overrides
# LLM_MODEL=openai/gpt-oss-120b
# LLM_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=your_openai_api_key   # fallback LLM key if GROQ_API_KEY is unset

# Where the agent persists tool results (the FastAPI server), used from M2
CLINICFLOW_API_URL=http://localhost:8000
