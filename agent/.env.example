# LiveKit Cloud (same project as the server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Voice pipeline providers
RUMIK_API_KEY=your_rumik_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
OPENAI_API_KEY=your_openai_api_key

# Where the agent persists tool results (the FastAPI server)
CLINICFLOW_API_URL=http://localhost:8000

# Optional: flip to a fallback TTS if Rumik is unavailable (M1+)
TTS_FALLBACK=false
